{
  "version": 2,
  "framework": null,
  "rewrites": [
    {
      "source": "/api/decisions",
      "destination": "/api/decisions.js"
    },
    {
      "source": "/api/task-feedback",
      "destination": "/api/task-feedback.js"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}